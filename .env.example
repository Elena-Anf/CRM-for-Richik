# Grooming CRM — Configuration
# Copy this file to .env and fill in the values

SECRET_KEY=change-me-in-production
DEBUG=True
DB_DRIVER=sqlite

# Google Calendar Integration (optional — Service Account)
# 1. Google Cloud Console → IAM & Admin → Service Accounts → Create Service Account
# 2. Name: grooming-crm → Create → Keys → Add Key → JSON → save as service-account.json
# 3. ID календаря Google указывается в карточке мастера (свой для каждого)

# GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
